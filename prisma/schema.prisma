generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Locale {
  EN
  NL
  FR
}

model SiteContent {
  id              Int      @id @default(1)
  isOpen          Boolean  @default(true)
  addressLine1    String   @default("NAAMSESTRAAT 55")
  addressLine2    String   @default("LEUVEN 3000")
  findUsUrl       String   @default("https://www.google.com/maps?q=Naamsestraat+55,+3000+Leuven,+Belgium")
  instagramUrl    String   @default("https://www.instagram.com/hygge.leuven/")
  mapLat          Float    @default(50.876568)
  mapLng          Float    @default(4.700649)
  mapZoom         Int      @default(16)
  publishedAt     DateTime?
  draftJson       String?
  updatedAt       DateTime @updatedAt
}

model Translation {
  id        Int      @id @default(autoincrement())
  namespace String
  locale    Locale
  value     String
  updatedAt DateTime @updatedAt

  @@unique([namespace, locale])
}

model OpeningHours {
  id        Int     @id @default(autoincrement())
  dayOfWeek Int     @unique
  opensAt   String?
  closesAt  String?
}

model Photo {
  id        Int      @id @default(autoincrement())
  path      String
  alt       String   @default("")
  role      String
  sortOrder Int      @default(0)
  refId     Int?
  createdAt DateTime @default(now())

  @@index([role, sortOrder])
}

model MenuCategory {
  id        Int        @id @default(autoincrement())
  slug      String     @unique
  sortOrder Int        @default(0)
  items     MenuItem[]
}

model MenuItem {
  id         Int          @id @default(autoincrement())
  categoryId Int
  category   MenuCategory @relation(fields: [categoryId], references: [id])
  priceCents Int
  photoId    Int?
  sortOrder  Int          @default(0)
  available  Boolean      @default(true)

  @@index([categoryId, sortOrder])
}

model InstagramAccount {
  id           Int       @id @default(autoincrement())
  handle       String
  accessToken  String
  userId       String
  tokenExpires DateTime?
  updatedAt    DateTime  @updatedAt
}

model InstagramPost {
  id        String   @id
  mediaUrl  String
  permalink String
  caption   String?
  mediaType String
  timestamp DateTime
  fetchedAt DateTime @default(now())
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  actor     String
  action    String
  entity    String
  entityId  String?
  diff      String?
  createdAt DateTime @default(now())
}
